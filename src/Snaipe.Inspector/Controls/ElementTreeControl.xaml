<UserControl
    x:Class="Snaipe.Inspector.Controls.ElementTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Snaipe.Inspector.Controls"
    xmlns:vm="using:Snaipe.Inspector.ViewModels">

    <UserControl.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Refresh Tree"
                Margin="4"
                Command="{x:Bind ViewModel.RefreshTreeCommand}"/>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <TreeView x:Name="ElementTree"
                      SelectionMode="Single">
                <TreeView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                            <TextBlock Text="{Binding Content.Node.TypeName}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#60A5FA"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding Content.Node.Name}"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       Foreground="#94A3B8"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding Content.Node.Name, Converter={StaticResource StringToVisibilityConverter}}" />

                            <Border Background="#1E3A8A"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="6,1"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding Content.TemplateLabelVisibility}">
                                <TextBlock Text="{Binding Content.TemplateLabel}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#BFDBFE"/>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </ScrollViewer>
    </Grid>
</UserControl>
