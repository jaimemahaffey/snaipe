<UserControl
    x:Class="Snaipe.Inspector.Controls.ElementTreeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Snaipe.Inspector.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Refresh Tree"
                Margin="4"
                Command="{x:Bind ViewModel.RefreshTreeCommand}"/>

        <TreeView x:Name="ElementTree"
                  Grid.Row="1"
                  SelectionMode="Single">
            <TreeView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Content.DisplayName}"
                               FontSize="12"/>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
