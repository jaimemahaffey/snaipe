<!-- src/Snaipe.Inspector/MainWindow.xaml -->
<Window
    x:Class="Snaipe.Inspector.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Snaipe.Inspector.Controls"
    xmlns:utu="http://uno.ui/toolkit"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls">

    <Grid Background="{StaticResource MainBackgroundGradient}">
        <Grid.Resources>
            <LinearGradientBrush x:Key="MainBackgroundGradient" StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="{ThemeResource SystemAltHighColor}" Offset="0.0"/>
                <GradientStop Color="{ThemeResource SystemAltLowColor}" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Header & Connection Bar -->
        <Border Grid.Row="0" 
                Padding="8"
                BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Background="{ThemeResource SystemControlBackgroundChromeLowBrush}">
            <controls:ConnectionBarControl />
        </Border>

        <!-- Main split: tree | property+preview -->
        <Grid Grid.Row="1" Padding="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- Visual Tree Pane (Left) -->
            <Border Grid.Column="0"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="12"
                    Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <controls:ElementTreeControl />
            </Border>

            <!-- Vertical Splitter -->
            <ctk:GridSplitter Grid.Column="1"
                             Width="1"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Stretch"
                             ResizeBehavior="BasedOnAlignment"
                             ResizeDirection="Columns"
                             Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"/>

            <!-- Right pane: property grid over preview -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="240" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Properties Pane (Top-Right) -->
                <Border Grid.Row="0"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                        CornerRadius="12"
                        Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                    <controls:PropertyGridControl DataContext="{x:Bind ViewModel.PropertyGrid}"
                                                    Host="{x:Bind ViewModel}"/>
                </Border>

                <!-- Horizontal Splitter -->
                <ctk:GridSplitter Grid.Row="1"
                                 Height="1"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 ResizeBehavior="BasedOnAlignment"
                                 ResizeDirection="Rows"
                                 Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"/>

                <!-- Preview Pane (Bottom-Right) -->
                <Border Grid.Row="2"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                        CornerRadius="12"
                        Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                    <controls:PreviewPaneControl />
                </Border>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" 
                Padding="16,8"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                Background="{ThemeResource SystemControlBackgroundChromeLowBrush}">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           FontFamily="Cascadia Code, Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
