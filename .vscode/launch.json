{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Inspector",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-solution",
      "program": "${workspaceFolder}/src/Snaipe.Inspector/bin/Debug/net9.0/Snaipe.Inspector.dll",
      "windows": {
        "program": "${workspaceFolder}/src/Snaipe.Inspector/bin/Debug/net9.0-windows/Snaipe.Inspector.dll"
      },
      "cwd": "${workspaceFolder}/src/Snaipe.Inspector",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "UNO_LINUX_FB_RENDERER": "wayland"
      }
    },
    {
      "name": "Run SampleApp",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-solution",
      "program": "${workspaceFolder}/samples/Snaipe.SampleApp/bin/Debug/net9.0/Snaipe.SampleApp.dll",
      "windows": {
        "program": "${workspaceFolder}/samples/Snaipe.SampleApp/bin/Debug/net9.0-windows/Snaipe.SampleApp.dll"
      },
      "cwd": "${workspaceFolder}/samples/Snaipe.SampleApp",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "UNO_LINUX_FB_RENDERER": "wayland"
      }
    }
  ],
  "compounds": [
    {
      "name": "SampleApp + Inspector (Both)",
      "configurations": [
        "Run SampleApp",
        "Run Inspector"
      ],
      "stopAll": true
    }
  ]
}